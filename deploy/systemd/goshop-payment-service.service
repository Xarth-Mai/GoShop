[Unit]
Description=GoShop payment service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/goshop
Environment=GOSHOP_CONFIG=/opt/goshop/config.yaml
ExecStart=/opt/goshop/bin/goshop-payment-service
Restart=always
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
